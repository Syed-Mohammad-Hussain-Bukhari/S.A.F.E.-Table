# API origin used by the SPA. Leave empty to use Vite's dev proxy
# (recommended in development — same-origin, no CORS).
# In production, set this to the backend's public URL, e.g. https://api.example.com
VITE_API_URL=

# Backend origin Vite proxies /api and /ws to during `vite dev`.
VITE_API_PROXY_TARGET=http://localhost:8000

# Optional: WebSocket origin override. Defaults to current origin (proxied).
VITE_WS_URL=
