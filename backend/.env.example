
# MongoDB
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=safetable

# Groq AI
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-70b-versatile

# Auth
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Server
HOST=0.0.0.0
PORT=8000

# ─── Environment ──────────────────────────────────────────────────────────
ENV=dev

# ─── MongoDB ──────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=safetable

# ─── Auth ─────────────────────────────────────────────────────────────────
# REQUIRED. Must be at least 32 chars and not start with "dev-", "changeme",
# "your-", or "safetable-dev". Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=__REPLACE_ME__
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ─── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Groq (LLM — voice ordering, chatbot, sentiment) ──────────────────────
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-70b-versatile

# ─── AssemblyAI (speech-to-text) ──────────────────────────────────────────
ASSEMBLYAI_API_KEY=
# Legacy fallback — prefer ASSEMBLYAI_API_KEY:
OPENAI_API_KEY=

# ─── HeyGen (TTS) ─────────────────────────────────────────────────────────
HEYGEN_API_KEY=
HEYGEN_VOICE_ID=1bd001e7e50f421d891986aad5158bc8

# ─── Stripe ───────────────────────────────────────────────────────────────
# Leave as the placeholders to run the demo in simulated mode.
# In production both must be real and STRIPE_WEBHOOK_SECRET is required.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=
